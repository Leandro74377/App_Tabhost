<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TabHost
        android:id="@android:id/tabhost"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TabWidget
                android:id="@android:id/tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <FrameLayout
                android:id="@android:id/tabcontent"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Pestaña Cuadrado -->
                <LinearLayout
                    android:id="@+id/tab1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_lado"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <EditText
                        android:id="@+id/et_lado_cuadrado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="Ingresa el lado"
                        android:padding="10dp" />

                    <Button
                        android:id="@+id/btn_calcular_cuadrado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_calcular"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_area"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="20dp" />

                    <TextView
                        android:id="@+id/tv_area_cuadrado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/resultado_vacio"
                        android:textSize="16sp"
                        android:padding="10dp"
                        android:background="@android:color/darker_gray" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_perimetro"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:id="@+id/tv_perimetro_cuadrado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/resultado_vacio"
                        android:textSize="16sp"
                        android:padding="10dp"
                        android:background="@android:color/darker_gray" />
                </LinearLayout>

                <!-- Pestaña Rectángulo -->
                <LinearLayout
                    android:id="@+id/tab2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_base"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <EditText
                        android:id="@+id/et_base_rectangulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="Ingresa la base"
                        android:padding="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_altura"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <EditText
                        android:id="@+id/et_altura_rectangulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="Ingresa la altura"
                        android:padding="10dp" />

                    <Button
                        android:id="@+id/btn_calcular_rectangulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_calcular"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_area"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="20dp" />

                    <TextView
                        android:id="@+id/tv_area_rectangulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/resultado_vacio"
                        android:textSize="16sp"
                        android:padding="10dp"
                        android:background="@android:color/darker_gray" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_perimetro"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:id="@+id/tv_perimetro_rectangulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/resultado_vacio"
                        android:textSize="16sp"
                        android:padding="10dp"
                        android:background="@android:color/darker_gray" />
                </LinearLayout>

                <!-- Pestaña Triángulo -->
                <LinearLayout
                    android:id="@+id/tab3"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_base_triangulo"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <EditText
                        android:id="@+id/et_base_triangulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="Ingresa la base"
                        android:padding="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_altura_triangulo"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <EditText
                        android:id="@+id/et_altura_triangulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="Ingresa la altura"
                        android:padding="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_lado_a"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <EditText
                        android:id="@+id/et_lado_a"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="Ingresa lado A"
                        android:padding="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_lado_b"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />

                    <EditText
                        android:id="@+id/et_lado_b"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="Ingresa lado B"
                        android:padding="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_lado_c"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp" />

                    <EditText
                        android:id="@+id/et_lado_c"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="Ingresa lado C"
                        android:padding="10dp" />

                    <Button
                        android:id="@+id/btn_calcular_triangulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_calcular"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_area"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:id="@+id/tv_area_triangulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/resultado_vacio"
                        android:textSize="16sp"
                        android:padding="10dp"
                        android:background="@android:color/darker_gray" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_perimetro"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:id="@+id/tv_perimetro_triangulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/resultado_vacio"
                        android:textSize="16sp"
                        android:padding="10dp"
                        android:background="@android:color/darker_gray" />
                </LinearLayout>

                <!-- Pestaña Círculo -->
                <LinearLayout
                    android:id="@+id/tab4"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_radio"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <EditText
                        android:id="@+id/et_radio_circulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="Ingresa el radio"
                        android:padding="10dp" />

                    <Button
                        android:id="@+id/btn_calcular_circulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_calcular"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_area"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="20dp" />

                    <TextView
                        android:id="@+id/tv_area_circulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/resultado_vacio"
                        android:textSize="16sp"
                        android:padding="10dp"
                        android:background="@android:color/darker_gray" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_perimetro"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:id="@+id/tv_perimetro_circulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/resultado_vacio"
                        android:textSize="16sp"
                        android:padding="10dp"
                        android:background="@android:color/darker_gray" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </TabHost>
</LinearLayout>
